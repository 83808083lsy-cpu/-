local lastAutoAdjustTime = 0
local autoAdjustRestore = { id = 0, prev = nil }
local function autoAdjustOffsets(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    if not lp or not lp.Character then return end
    local now = tick()
    if now - lastAutoAdjustTime < 1.6 then return end
    lastAutoAdjustTime = now

    local root = lp.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local head = targetPlayer.Character:FindFirstChild("Head")
    if not head then return end

    local downOrigin = Vector3.new(head.Position.X, head.Position.Y + 5, head.Position.Z)
    local rparams = RaycastParams.new()
    rparams.FilterDescendantsInstances = { lp.Character, targetPlayer.Character }
    rparams.FilterType = Enum.RaycastFilterType.Blacklist
    rparams.IgnoreWater = true
    local res = workspace:Raycast(downOrigin, Vector3.new(0, -200, 0), rparams)
    local groundY = res and res.Position.Y or (head.Position.Y - 3)
    local suggestedUp = math.clamp((head.Position.Y - groundY) * 0.8 + 1, 0, 40)

    local capSide = math.clamp(cfg.offset or 40, 0, 40)
    local sideStep = math.max(1, cfg.autoAdjustSideStep or 2)
    local heightCandidates = { suggestedUp, math.max(0, suggestedUp - 1), suggestedUp + 1 }
    local rightVec = root.CFrame.RightVector
    local forwardVec = root.CFrame.LookVector
    local fwdCandidates = {0, 1.5, -1.5}

    local overlapParams = OverlapParams.new()
    overlapParams.FilterDescendantsInstances = { lp.Character }
    overlapParams.FilterType = Enum.RaycastFilterType.Blacklist
    overlapParams.MaxParts = 12

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { lp.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    local bestScore = -1
    local bestSignedSide = cfg.sideDirection * (cfg.sideOffset or 0)
    local sides = {}
    for s = 0, capSide, sideStep do table.insert(sides, s) end
    if cfg.preferMaxOffset then table.sort(sides, function(a,b) return a > b end) end

    local breakEarly = false
    for _, s in ipairs(sides) do
        for _, sideSign in ipairs({-1, 1}) do
            local sideVal = s * sideSign
            local scorePos = 0
            for _, fwd in ipairs(fwdCandidates) do
                for _, h in ipairs(heightCandidates) do
                    local cand = root.Position + Vector3.new(0, h, 0) + rightVec * sideVal + forwardVec * fwd
                    local ok, nearby = pcall(function() return workspace:GetPartBoundsInRadius(cand, 0.6, overlapParams) end)
                    local insideSolid = false
                    if ok and nearby and #nearby > 0 then
                        for _, part in ipairs(nearby) do
                            if part and part.CanCollide and not part:IsDescendantOf(targetPlayer.Character) then insideSolid = true; break end
                        end
                    end
                    if not insideSolid then
                        local upHit = workspace:Raycast(cand, Vector3.new(0, 1.6, 0), rayParams)
                        local pathClear = isPathClearStrict(cand, head.Position, targetPlayer.Character, cfg.sampleRadius, cfg.scanSampleCount)
                        if not upHit and pathClear then scorePos = scorePos + 4
                        elseif not upHit or pathClear then scorePos = scorePos + 2
                        else scorePos = scorePos + 1 end
                    end
                end
            end
            if scorePos > bestScore or (scorePos == bestScore and math.abs(sideVal) > math.abs(bestSignedSide)) then
                bestScore = scorePos
                bestSignedSide = sideVal
            end
            if cfg.preferMaxOffset and bestScore >= (#heightCandidates * #fwdCandidates * 4 * 0.8) then
                breakEarly = true
                break
            end
        end
        if breakEarly then break end
    end

    if bestScore >= 1 then
        local newSideMag = math.clamp(math.floor(math.abs(bestSignedSide) + 0.5), 0, capSide)
        local newUp = math.clamp(math.floor(suggestedUp + 0.5), 0, 40)
        local prevSide = math.clamp(cfg.sideOffset or 0, 0, capSide)
        local prevUp = math.clamp(cfg.upOffset or 0, 0, 40)
        local prevOffset = math.clamp(cfg.offset or 0, 0, capSide)

        autoAdjustRestore.id = autoAdjustRestore.id + 1
        local myId = autoAdjustRestore.id
        autoAdjustRestore.prev = { sideOffset = prevSide, upOffset = prevUp, offset = prevOffset, sideDirection = cfg.sideDirection or 1 }

        cfg.sideOffset = newSideMag
        cfg.upOffset = newUp
        cfg.offset = math.floor((cfg.sideOffset + cfg.upOffset) / 2 + 0.5)
        cfg.sideDirection = (bestSignedSide >= 0) and 1 or -1

        spawn(function()
            wait(cfg.autoAdjustRestoreDelay or 1.0)
            if autoAdjustRestore.id == myId and autoAdjustRestore.prev then
                local capNow = math.clamp(cfg.offset or 40, 0, 40)
                pcall(function()
                    cfg.sideOffset = math.clamp(autoAdjustRestore.prev.sideOffset or cfg.sideOffset, 0, capNow)
                    cfg.upOffset = math.clamp(autoAdjustRestore.prev.upOffset or cfg.upOffset, 0, 40)
                    cfg.offset = math.clamp(autoAdjustRestore.prev.offset or cfg.offset, 0, capNow)
                    cfg.sideDirection = autoAdjustRestore.prev.sideDirection or cfg.sideDirection
                end)
                autoAdjustRestore.prev = nil
            end
        end)
    end
end

local function get_target()
    if not lp or not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return nil end
    local originPos = lp.Character.HumanoidRootPart.Position
    local candidates = {}
    for _, p in next, Players:GetPlayers() do
        if p ~= lp and p.Character then
            local head = p.Character:FindFirstChild("Head")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if head and hum and hum.Health > 0 then
                local dist = (originPos - head.Position).Magnitude
                if dist <= (cfg.maxScanDistance or 120) then
                    if cfg.skipFriends then
                        if not isFriendSafe(p) then table.insert(candidates, {player = p, dist = dist}) end
                    else
                        table.insert(candidates, {player = p, dist = dist})
                    end
                end
            end
        end
    end
    if #candidates == 0 then return nil end
    table.sort(candidates, function(a,b) return a.dist < b.dist end)
    if cfg.prioritizeNearest then return candidates[1].player end
    local maxChecks = math.min(#candidates, cfg.scanMaxChecks)
    for i = 1, maxChecks do
        local p = candidates[i].player
        local ok, candidate, resolved = pcall(function()
            local sideArg = (cfg.sideOffset or 0) * (cfg.sideDirection or 1)
            return findClearOrigin(p, cfg.upOffset, math.abs(sideArg), math.abs(sideArg), math.max(6, cfg.attempts))
        end)
        if ok and candidate and resolved and resolved.hit then return p end
    end
    return candidates[1].player
end

RunService.Heartbeat:Connect(function(dt)
    if lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then updatePositionHistory(lp, lp.Character.HumanoidRootPart.Position) end

    if os.clock() - last_attack < cooldown then return end
    if not cfg.rageEnabled then return end
    if not lp or not lp.Character then return end
    local char = lp.Character
    local tool = char and char:FindFirstChildOfClass("Tool")
    if not char or not tool or not char:FindFirstChild("HumanoidRootPart") then return end

    if lockedTarget.expiry < tick() then
        lockedTarget.player = nil; lockedTarget.predictions = nil; lockedTarget.confidence = 0; lockedTarget.consecutive = 0; lockedTarget.precomputed = nil; lockedTarget.precomputeExpiry = 0
    end

    local enemy = nil
    if lockedTarget.player and lockedTarget.predictions then
        local p = lockedTarget.player
        if p and p.Character and p.Character:FindFirstChild("Head") and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            enemy = p
        else
            lockedTarget.player = nil; enemy = nil
        end
    end
    if not enemy then enemy = get_target() end
    if not enemy then return end
    if cfg.skipFriends and isFriendSafe(enemy) then return end

    autoAdjustOffsets(enemy)

    local origin, resolved = nil, nil

    if lockedTarget.player == enemy and lockedTarget.precomputed and #lockedTarget.precomputed > 0 then
        if lockedTarget.precomputeExpiry < tick() then
            spawn(function()
                if lockedTarget.player == enemy and lockedTarget.predictions then
                    precomputeStrikePoints(enemy, lockedTarget.predictions.origin, lockedTarget.predictions.hitPos)
                end
            end)
        end
        for _, cand in ipairs(lockedTarget.precomputed) do
            if cand and cand.origin and cand.hitPos and cand.resolved then
                local check = resolveHitWithPenetration(cand.origin, cand.hitPos, enemy.Character)
                if check and check.hit then
                    origin = cand.origin
                    resolved = check
                    break
                end
            end
        end
    end

    if not origin and lockedTarget.player == enemy and lockedTarget.predictions and lockedTarget.predictions.origin and lockedTarget.predictions.hitPos then
        local qr = resolveHitWithPenetration(lockedTarget.predictions.origin, lockedTarget.predictions.hitPos, enemy.Character)
        if qr and qr.hit then origin = lockedTarget.predictions.origin; resolved = qr end
    end

    if not origin then
        local sideArg = (cfg.sideOffset or 0) * (cfg.sideDirection or 1)
        origin, resolved = findClearOrigin(enemy, cfg.upOffset, math.abs(sideArg), math.abs(sideArg), cfg.attempts)
    end

    if not origin or not resolved or not resolved.hit then return end

    local finalHitPos = resolved.hitPosition
    if cfg.leadEnabled then
        local dist = (finalHitPos - origin).Magnitude
        local travelTime = math.clamp(dist / math.max(1, cfg.bulletSpeedEst), 0, cfg.maxPrediction)
        local targetVel = getVelocityEstimate(enemy)
        local ourVel = posHistory[lp] and posHistory[lp].vel or Vector3.new(0,0,0)
        local predicted = predictPosition(finalHitPos, targetVel, travelTime) - ourVel * travelTime
        local pr = resolveHitWithPenetration(origin, predicted, enemy.Character)
        if pr and pr.hit then
            finalHitPos = pr.hitPosition
            resolved = pr
        end
    end

    if not resolved or not resolved.hit then return end

    last_attack = os.clock()
    pcall(function()
        if action_sync then
            action_sync:FireServer({
                origin = origin,
                direction = (resolved.hitPosition - origin).Unit,
                hitPosition = resolved.hitPosition,
                hitInstance = resolved.hitInstance,
                hitHumanoid = resolved.hitHumanoid,
                IsHeadshot = resolved.isHeadshot or false
            })
        end
    end)
    pcall(function() if muzzle_flash then muzzle_flash:FireServer() end end)
    pcall(function() if fake_bullet then fake_bullet:FireServer(CFrame.new(origin, resolved.hitPosition), (resolved.hitPosition - origin).Unit) end end)

    spawnTracer(origin, resolved.hitPosition, { Color = cfg.tracerColor, Thickness = cfg.tracerThickness, Lifetime = cfg.tracerLifetime })
    spawnImpactEffect(resolved.hitPosition)

    pcall(function()
        if lastInfoLabel then
            local rootPos = char.HumanoidRootPart.Position
            local rel = origin - rootPos
            local rightVec = char.HumanoidRootPart.CFrame.RightVector
            local lookVec = char.HumanoidRootPart.CFrame.LookVector
            local sideVal = rel:Dot(rightVec)
            local upVal   = rel.Y
            local fwdVal  = rel:Dot(lookVec)
            local hp = resolved.hitPosition
            safeSetText(lastInfoLabel, string.format("上次偏移 -> 侧向: %d  垂直: %d  前向: %d\n上次命中 -> (%.1f, %.1f, %.1f)",
                math.floor((sideVal or 0)+0.5), math.floor((upVal or 0)+0.5), math.floor((fwdVal or 0)+0.5), hp.X or 0, hp.Y or 0, hp.Z or 0))
        end
    end)
end)
