local function isPathClearStrict(origin, targetPos, targetCharacter, sampleRadius, sampleCount)
    sampleRadius = sampleRadius or cfg.sampleRadius
    sampleCount = math.max(1, sampleCount or cfg.sampleCount)
    if not origin or not targetPos then return false end
    local dir = targetPos - origin
    local dist = dir.Magnitude
    if dist <= 0 then return false end
    local dirUnit = dir.Unit
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { lp.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    local centerHit = workspace:Raycast(origin, dir, rayParams)
    if centerHit and not (centerHit.Instance and centerHit.Instance:IsDescendantOf(targetCharacter)) then
        return false
    end

    local upGuess = Vector3.new(0,1,0)
    local right = dirUnit:Cross(upGuess)
    if right.Magnitude < 1e-3 then upGuess = Vector3.new(1,0,0); right = dirUnit:Cross(upGuess) end
    right = right.Unit
    local up = right:Cross(dirUnit).Unit

    for i = 0, sampleCount - 1 do
        local angle = (i / sampleCount) * math.pi * 2
        local offset = right * (math.cos(angle) * sampleRadius) + up * (math.sin(angle) * sampleRadius)
        local sampleOrigin = origin + offset
        local sampleDir = targetPos - sampleOrigin
        if sampleDir.Magnitude > 0.001 then
            local hit = workspace:Raycast(sampleOrigin, sampleDir, rayParams)
            if hit and not (hit.Instance and hit.Instance:IsDescendantOf(targetCharacter)) then
                return false
            end
        end
    end
    return true
end

local function resolveHitWithPenetration(origin, targetPos, targetCharacter)
    if not origin or not targetPos then return nil end
    local dir = targetPos - origin
    local totalDist = dir.Magnitude
    if totalDist <= 0 then return nil end
    local dirUnit = dir.Unit

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { lp.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    local currentOrigin = origin
    local penetratedSum = 0
    local maxThickness = cfg.maxThickness
    local step = cfg.penetrationStep

    local iterLimit = 200
    local iter = 0
    while iter < iterLimit do
        iter = iter + 1
        local remainingDir = targetPos - currentOrigin
        if remainingDir.Magnitude <= 0.01 then
            return {hit = true, hitPosition = targetPos, hitInstance = targetCharacter:FindFirstChild("Head"), hitHumanoid = targetCharacter:FindFirstChildOfClass("Humanoid"), isHeadshot = true}
        end

        local ok, result = pcall(function() return workspace:Raycast(currentOrigin, remainingDir, rayParams) end)
        if not ok then result = nil end

        if not result then
            return {hit = true, hitPosition = targetPos, hitInstance = targetCharacter:FindFirstChild("Head"), hitHumanoid = targetCharacter:FindFirstChildOfClass("Humanoid"), isHeadshot = true}
        end

        if result.Instance and result.Instance:IsDescendantOf(targetCharacter) then
            local isHeadshot = result.Instance.Name:lower():match("head") ~= nil
            local mdl = result.Instance:FindFirstAncestorOfClass("Model")
            local hum = mdl and mdl:FindFirstChildOfClass("Humanoid") or targetCharacter:FindFirstChildOfClass("Humanoid")
            return {hit = true, hitPosition = result.Position or targetPos, hitInstance = result.Instance, hitHumanoid = hum, isHeadshot = isHeadshot}
        end

        if not cfg.penetrationEnabled then
            return {hit = false, hitPosition = (result.Position or (currentOrigin + dirUnit * 0.01)), hitInstance = result.Instance, hitHumanoid = nil, isHeadshot = false}
        end

        local exitFound = false
        local exitPos = nil
        local pos = (result.Position or currentOrigin) + dirUnit * (step * 0.5)
        local overlapParams = OverlapParams.new()
        overlapParams.FilterDescendantsInstances = { lp.Character }
        overlapParams.FilterType = Enum.RaycastFilterType.Blacklist

        local maxSteps = math.ceil((maxThickness - penetratedSum) / step)
        if maxSteps <= 0 then
            return {hit = false, hitPosition = (result.Position or currentOrigin), hitInstance = result.Instance, hitHumanoid = nil, isHeadshot = false}
        end

        for i = 1, maxSteps do
            local ok2, parts = pcall(function() return workspace:GetPartBoundsInRadius(pos, step * 0.4, overlapParams) end)
            local insideSolid = false
            if ok2 and parts and #parts > 0 then
                for _, part in ipairs(parts) do
                    if part and part.CanCollide and not part:IsDescendantOf(targetCharacter) then
                        insideSolid = true
                        break
                    end
                end
            end
            if not insideSolid then
                exitFound = true
                exitPos = pos
                break
            end
            pos = pos + dirUnit * step
        end

        if not exitFound then
            return {hit = false, hitPosition = (result.Position or currentOrigin), hitInstance = result.Instance, hitHumanoid = nil, isHeadshot = false}
        end

        penetratedSum = penetratedSum + (exitPos - (result.Position or currentOrigin)).Magnitude
        if penetratedSum > maxThickness then
            return {hit = false, hitPosition = (result.Position or currentOrigin), hitInstance = result.Instance, hitHumanoid = nil, isHeadshot = false}
        end

        currentOrigin = exitPos + dirUnit * 0.01
    end

    return {hit = false, hitPosition = targetPos, hitInstance = nil, hitHumanoid = nil, isHeadshot = false}
end

local function autoAdjustCandidate(rootPos, side, fwdOffset, initHeight, rightVec, forwardVec, leftLimit, rightLimit, overlapParams, rayParams)
    local maxExtra = cfg.autoAdjustMaxExtraUp or 6
    local stepH = cfg.autoAdjustVerticalStep or 0.5

    for dh = 0, maxExtra, stepH do
        local h = initHeight + dh
        if h > 40 then break end
        local cand = rootPos + Vector3.new(0, h, 0) + rightVec * side + forwardVec * fwdOffset
        local ok, nearby = pcall(function() return workspace:GetPartBoundsInRadius(cand, 0.6, overlapParams) end)
        local insideSolid = false
        if ok and nearby and #nearby > 0 then
            for _, part in ipairs(nearby) do
                if part and part.CanCollide then insideSolid = true; break end
            end
        end
        if not insideSolid then
            local upHit = workspace:Raycast(cand, Vector3.new(0, 1.6, 0), rayParams)
            if not upHit then return cand, h, side end
        end
    end

    for dh = stepH, math.min(initHeight, 6), stepH do
        local h = initHeight - dh
        if h < 0 then break end
        local cand = rootPos + Vector3.new(0, h, 0) + rightVec * side + forwardVec * fwdOffset
        local ok, nearby = pcall(function() return workspace:GetPartBoundsInRadius(cand, 0.6, overlapParams) end)
        local insideSolid = false
        if ok and nearby and #nearby > 0 then
            for _, part in ipairs(nearby) do
                if part and part.CanCollide then insideSolid = true; break end
            end
        end
        if not insideSolid then
            local upHit = workspace:Raycast(cand, Vector3.new(0, 1.6, 0), rayParams)
            if not upHit then return cand, h, side end
        end
    end

    local maxSideAdjust = math.max(leftLimit or 0, rightLimit or 0)
    local stepSide = math.max(1, cfg.autoAdjustSideStep or 2)
    for s = stepSide, maxSideAdjust, stepSide do
        local candidatesides = {}
        if side and side > 0 then table.insert(candidatesides, math.max(0, side - s)) end
        if side and side < 0 then table.insert(candidatesides, math.min(0, side + s)) end
        table.insert(candidatesides, (side or 0) + s); table.insert(candidatesides, (side or 0) - s)
        for _, newSide in ipairs(candidatesides) do
            if newSide and newSide >= -(leftLimit or 0) and newSide <= (rightLimit or 0) then
                for dh = 0, maxExtra, stepH do
                    local h = initHeight + dh
                    if h > 40 then break end
                    local cand = rootPos + Vector3.new(0, h, 0) + rightVec * newSide + forwardVec * fwdOffset
                    local ok, nearby = pcall(function() return workspace:GetPartBoundsInRadius(cand, 0.6, overlapParams) end)
                    local insideSolid = false
                    if ok and nearby and #nearby > 0 then
                        for _, part in ipairs(nearby) do
                            if part and part.CanCollide then insideSolid = true; break end
                        end
                    end
                    if not insideSolid then
                        local upHit = workspace:Raycast(cand, Vector3.new(0, 1.6, 0), rayParams)
                        if not upHit then return cand, h, newSide end
                    end
                end
            end
        end
    end

    return nil
end

local function findClearOrigin(targetPlayer, upOffset, leftOffset, rightOffset, attempts, sampleCountOverride)
    attempts = attempts or cfg.attempts
    upOffset = upOffset or cfg.upOffset or 0
    leftOffset = leftOffset or cfg.sideOffset or 0
    rightOffset = rightOffset or cfg.sideOffset or 0
    local cap = math.clamp(cfg.offset or 40, 0, 40)
    leftOffset = math.clamp(leftOffset, 0, cap)
    rightOffset = math.clamp(rightOffset, 0, cap)

    if not lp or not lp.Character then return nil end
    local root = lp.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    if not targetPlayer or not targetPlayer.Character then return nil end
    local targetHead = targetPlayer.Character:FindFirstChild("Head")
    if not targetHead then return nil end

    local forward = root.CFrame.LookVector
    local right = root.CFrame.RightVector
    local up = Vector3.new(0, 1, 0)

    local overlapParams = OverlapParams.new()
    overlapParams.FilterDescendantsInstances = { lp.Character }
    overlapParams.FilterType = Enum.RaycastFilterType.Blacklist
    overlapParams.MaxParts = 12

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { lp.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    local stepSide = math.max(1, cfg.autoAdjustSideStep or 2)
    local rawSides = {}
    rawSides[1] = 0
    local idx = 2
    for s = stepSide, cap, stepSide do
        rawSides[idx] = -s; idx = idx + 1
        rawSides[idx] = s; idx = idx + 1
    end
    if cap > 0 and (cap % stepSide) ~= 0 then
        table.insert(rawSides, -cap)
        table.insert(rawSides, cap)
    end
    local seen = {}
    local uniq = {}
    for _, v in ipairs(rawSides) do
        if not seen[v] then
            seen[v] = true
            table.insert(uniq, v)
        end
    end
    rawSides = uniq

    table.sort(rawSides, function(a,b)
        local sa = (a >= 0) and 1 or -1
        local sb = (b >= 0) and 1 or -1
        if cfg.sideDirection and sa ~= sb then
            return sa == cfg.sideDirection
        end
        if cfg.preferMaxOffset then
            return math.abs(a) > math.abs(b)
        else
            return math.abs(a) < math.abs(b)
        end
    end)

    local function tryCandidate(side, fwd)
        local rootPos = root.Position
        local cand, usedH, usedSide = autoAdjustCandidate(rootPos, side, fwd, upOffset, right, forward, leftOffset, rightOffset, overlapParams, rayParams)
        if not cand then return false end

        local sampleCount = math.max(1, tonumber(sampleCountOverride) or cfg.sampleCount)
        local aimOffsets = { Vector3.new(0, 0, 0) }
        for j = 1, math.max(4, sampleCount) do
            local angle = (j / sampleCount) * math.pi * 2
            local radius = cfg.hitRadius * (0.6 + 0.4 * ((j % 2)))
            local off = right * math.cos(angle) * radius + up * math.sin(angle) * radius
            table.insert(aimOffsets, off)
        end

        for _, off in ipairs(aimOffsets) do
            local aimPos = targetHead.Position + off
            local resolved = resolveHitWithPenetration(cand, aimPos, targetPlayer.Character)
            if resolved and resolved.hit then
                return true, cand, resolved, usedSide or side, usedH or upOffset, off
            end
        end
        return false
    end

    local function tryOutsideCandidate()
        if not cfg.outsideOffsetEnabled then return nil end
        local outsideDist = math.clamp(cfg.outsideOffsetDistance or 3, 0, 40)
        local rootPos = root.Position
        local fwdOffsets = {0, 2, -2}
        local dirVecs = {
            right, right * -1,
            forward, forward * -1,
            Vector3.new(0,1,0), Vector3.new(0,-1,0)
        }
        for _, dv in ipairs(dirVecs) do
            for _, fwd in ipairs(fwdOffsets) do
                local candPos = rootPos + dv * (cap + outsideDist) + forward * fwd + Vector3.new(0, upOffset, 0)
                local ok, nearby = pcall(function() return workspace:GetPartBoundsInRadius(candPos, 0.6, overlapParams) end)
                local insideSolid = false
                if ok and nearby and #nearby > 0 then
                    for _, part in ipairs(nearby) do
                        if part and part.CanCollide and not part:IsDescendantOf(targetPlayer.Character) then insideSolid = true; break end
                    end
                end
                if insideSolid then
                else
                    local sampleCount = math.max(1, tonumber(sampleCountOverride) or cfg.sampleCount)
                    local aimOffsets = { Vector3.new(0, 0, 0) }
                    for j = 1, math.max(4, sampleCount) do
                        local angle = (j / sampleCount) * math.pi * 2
                        local radius = cfg.hitRadius * (0.6 + 0.4 * ((j % 2)))
                        local off = right * math.cos(angle) * radius + up * math.sin(angle) * radius
                        table.insert(aimOffsets, off)
                    end
                    for _, off in ipairs(aimOffsets) do
                        local aimPos = targetHead.Position + off
                        local resolved = resolveHitWithPenetration(candPos, aimPos, targetPlayer.Character)
                        if resolved and resolved.hit then
                            local usedSide = 0
                            pcall(function() usedSide = (candPos - rootPos):Dot(right) end)
                            usedSide = math.clamp(math.floor(usedSide + 0.5), -cap, cap)
                            local usedH = math.clamp(math.floor(upOffset + 0.5), 0, 40)
                            return candPos, resolved, usedSide, usedH, off
                        end
                    end
                end
            end
        end
        return nil
    end

    if cfg.outsideOffsetEnabled then
        local ocand, oresolved, usedSide, usedH, off = tryOutsideCandidate()
        if ocand and oresolved and oresolved.hit then
            return ocand, oresolved, usedSide, usedH, off
        end
    end

    for _, side in ipairs(rawSides) do
        local fwdOffsets = {0, 2, -2}
        for _, fwd in ipairs(fwdOffsets) do
            local ok, cand, resolved, usedSide, usedH, aimOff = tryCandidate(side, fwd)
            if ok then return cand, resolved, usedSide, usedH, aimOff end
        end
    end

    for i = 1, attempts do
        local side
        if math.random() < 0.75 then
            local sign = (math.random() < 0.5) and -1 or 1
            side = sign * (0.6 + 0.4 * math.random()) * cap
        else
            side = (math.random() * (leftOffset + rightOffset)) - leftOffset
            side = math.clamp(side, -leftOffset, rightOffset)
        end
        local fwd = (math.random() * 2 - 1) * 5
        local ok, cand, resolved, usedSide, usedH, aimOff = tryCandidate(side, fwd)
        if ok then return cand, resolved, usedSide, usedH, aimOff end
    end

    return nil
end

local function isFriendSafe(player)
    if not lp or not player then return false end
    local ok, res = pcall(function() return lp:IsFriendsWith(player.UserId) end)
    return ok and res
end

local function getNearbyCandidates()
    if not lp or not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return {} end
    local originPos = lp.Character.HumanoidRootPart.Position
    local list = {}
    for _, p in next, Players:GetPlayers() do
        if p ~= lp and p.Character then
            local head = p.Character:FindFirstChild("Head")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if head and hum and hum.Health > 0 then
                local dist = (originPos - head.Position).Magnitude
                if dist <= (cfg.maxScanDistance or 120) then
                    if cfg.skipFriends then
                        if not isFriendSafe(p) then table.insert(list, {player = p, dist = dist}) end
                    else
                        table.insert(list, {player = p, dist = dist})
                    end
                end
            end
        end
    end
    table.sort(list, function(a,b) return a.dist < b.dist end)
    return list
end

local quickCache = {}
local quickCacheTTL = 0.6

local function quickEvaluateTarget(p)
    if not p or not p.Character then return nil end
    local cached = quickCache[p]
    if cached and tick() - cached.ts < quickCacheTTL then
        return cached.data
    end

    local head = p.Character:FindFirstChild("Head")
    if not head then return nil end
    updatePositionHistory(p, head.Position)

    local ok, candidate, resolved = pcall(function()
        return findClearOrigin(p, cfg.upOffset, cfg.sideOffset, cfg.sideOffset, math.max(3, math.floor(cfg.attempts/3)), cfg.scanSampleCount)
    end)
    if not ok or not candidate or not resolved or not resolved.hit then
        quickCache[p] = { ts = tick(), data = nil }
        return nil
    end

    local pathClear = isPathClearStrict(candidate, resolved.hitPosition, p.Character, cfg.sampleRadius, math.max(3, cfg.scanSampleCount))
    local data = { player = p, origin = candidate, resolved = resolved, confidence = (pathClear and 2 or 1) }
    quickCache[p] = { ts = tick(), data = data }
    return data
end

local function getVelocityEstimate(player)
    local h = posHistory[player]
    if not h then return Vector3.new(0,0,0) end
    return h.vel or Vector3.new(0,0,0)
end

local function predictPosition(pos, vel, travelTime)
    local t = math.clamp(travelTime, 0, cfg.maxPrediction)
    return pos + vel * t
end

local lockedTarget = { player = nil, expiry = 0, predictions = nil, confidence = 0, consecutive = 0, precomputed = nil, precomputeExpiry = 0 }

local function precomputeStrikePoints(targetPlayer, baseOrigin, baseHitPos)
    if not targetPlayer or not targetPlayer.Character then return end
    if not lp or not lp.Character then return end
    local root = lp.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local cap = math.clamp(cfg.offset or 40, 0, 40)
    local stepSide = math.max(1, cfg.autoAdjustSideStep or 2)
    local rightVec = root.CFrame.RightVector
    local forwardVec = root.CFrame.LookVector

    local overlapParams = OverlapParams.new()
    overlapParams.FilterDescendantsInstances = { lp.Character }
    overlapParams.FilterType = Enum.RaycastFilterType.Blacklist
    overlapParams.MaxParts = 10

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { lp.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    local candidates = {}
    local sides = {}
    for s = 0, cap, stepSide do table.insert(sides, s) end
    if cfg.preferMaxOffset then table.sort(sides, function(a,b) return a > b end) else table.sort(sides, function(a,b) return a < b end) end

    local upCandidates = { cfg.upOffset, math.max(0, cfg.upOffset - 1), cfg.upOffset + 1 }

    for _, s in ipairs(sides) do
        for _, sign in ipairs({-1, 1}) do
            local sideVal = s * sign
            for _, fwd in ipairs({0, 1.5, -1.5}) do
                for _, upDelta in ipairs(upCandidates) do
                    local candPos = root.Position + Vector3.new(0, upDelta, 0) + rightVec * sideVal + forwardVec * fwd
                    local ok, nearby = pcall(function() return workspace:GetPartBoundsInRadius(candPos, 0.5, overlapParams) end)
                    local insideSolid = false
                    if ok and nearby and #nearby > 0 then
                        for _, part in ipairs(nearby) do
                            if part and part.CanCollide and not part:IsDescendantOf(targetPlayer.Character) then insideSolid = true; break end
                        end
                    end
                    if insideSolid then
                    else
                        local distBase = (baseHitPos - candPos).Magnitude
                        local travelTime = (cfg.leadEnabled and (distBase / math.max(1, cfg.bulletSpeedEst))) or 0
                        travelTime = math.clamp(travelTime, 0, cfg.maxPrediction)
                        local targetVel = getVelocityEstimate(targetPlayer)
                        local ourVel = posHistory[lp] and posHistory[lp].vel or Vector3.new(0,0,0)
                        local predHit = baseHitPos
                        if cfg.leadEnabled then predHit = predictPosition(baseHitPos, targetVel, travelTime) - ourVel * travelTime end
                        local resolved = resolveHitWithPenetration(candPos, predHit, targetPlayer.Character)
                        if resolved and resolved.hit then
                            local score = 0
                            local pathClear = isPathClearStrict(candPos, resolved.hitPosition, targetPlayer.Character, cfg.sampleRadius, math.max(3, cfg.scanSampleCount))
                            if pathClear then score = score + 4 else score = score + 1 end
                            if resolved.isHeadshot then score = score + 3 end
                            if cfg.preferMaxOffset then score = score + math.abs(sideVal)/10 else score = score + (1/(1+math.abs(sideVal))) end
                            table.insert(candidates, { origin = candPos, hitPos = resolved.hitPosition, resolved = resolved, score = score })
                        end
                    end
                    if #candidates >= cfg.precomputeCount * 4 then break end
                end
                if #candidates >= cfg.precomputeCount * 4 then break end
            end
            if #candidates >= cfg.precomputeCount * 4 then break end
        end
        if #candidates >= cfg.precomputeCount * 4 then break end
    end

    table.sort(candidates, function(a,b) return a.score > b.score end)
    local selected = {}
    for i = 1, math.min(cfg.precomputeCount, #candidates) do table.insert(selected, candidates[i]) end

    if lockedTarget.player == targetPlayer then
        lockedTarget.precomputed = selected
        lockedTarget.precomputeExpiry = tick() + cfg.precomputeRefreshInterval
    end
end

spawn(function()
