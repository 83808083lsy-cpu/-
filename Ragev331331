-- Utility: create a simple draggable slider (mouse + touch) with optional formatter
local function createSlider(parent, labelText, minVal, maxVal, defaultVal, width, onChanged, fmt)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0, width, 0, 48)
    container.BackgroundTransparency = 1
    container.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.SourceSansSemibold
    label.TextSize = 14
    label.TextColor3 = Color3.fromRGB(120, 140, 160)
    label.Parent = container

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0.4, 0, 1, 0)
    valueLabel.Position = UDim2.new(0.6, 0, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(defaultVal)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Font = Enum.Font.SourceSans
    valueLabel.TextSize = 14
    valueLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    valueLabel.Parent = container

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, 0, 0, 10)
    track.Position = UDim2.new(0, 0, 1, -12)
    track.BackgroundColor3 = Color3.fromRGB(40, 44, 48)
    track.Parent = container
    track.AnchorPoint = Vector2.new(0, 0)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.Position = UDim2.new(0, 0, 0, 0)
    fill.BackgroundColor3 = Color3.fromRGB(96, 108, 122)
    fill.Parent = track

    local handle = Instance.new("ImageLabel")
    handle.Size = UDim2.new(0, 14, 0, 14)
    handle.Position = UDim2.new(0, -7, -0.3, 0)
    handle.BackgroundColor3 = Color3.fromRGB(160, 170, 180)
    handle.Parent = track
    handle.Active = true

    local dragging = false
    local function formatVal(v)
        if fmt then return fmt(v) end
        return tostring(math.floor(v * 100 + 0.5) / 100)
    end

    local function setFromPos(x)
        local absX = math.clamp(x - track.AbsolutePosition.X, 0, track.AbsoluteSize.X)
        local t = 0
        if track.AbsoluteSize.X > 0 then
            t = absX / track.AbsoluteSize.X
        end
        local val = minVal + (maxVal - minVal) * t
        val = math.max(minVal, math.min(maxVal, val))
        if onChanged then onChanged(val) end
        fill.Size = UDim2.new(t, 0, 1, 0)
        handle.Position = UDim2.new(t, -7, -0.3, 0)
        valueLabel.Text = formatVal(val)
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            setFromPos(input.Position.X)
        end
    end)
    track.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            setFromPos(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    track:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        if maxVal == minVal then return end
        local t = (defaultVal - minVal) / (maxVal - minVal)
        t = math.clamp(t, 0, 1)
        fill.Size = UDim2.new(t, 0, 1, 0)
        handle.Position = UDim2.new(t, -7, -0.3, 0)
        valueLabel.Text = formatVal(defaultVal)
        if onChanged then onChanged(defaultVal) end
    end)

    return container
end

