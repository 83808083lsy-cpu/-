-- Tracer (purple) and impact visuals
local function spawnTracer(origin, hitPosition, opts)
    -- Respect tracer enabled flag
    if not cfg.tracerEnabled then return end

    opts = opts or {}
    local color = opts.Color or cfg.tracerColor
    local thickness = opts.Thickness or cfg.tracerThickness
    local lifetime = opts.Lifetime or cfg.tracerLifetime -- 默认现在为 30 秒

    local dist = (hitPosition - origin).Magnitude
    if dist <= 0 then return end

    local tracer = Instance.new("Part")
    tracer.Name = "BulletTracer"
    tracer.Anchored = true
    tracer.CanCollide = false
    tracer.Size = Vector3.new(thickness, thickness, dist)
    tracer.Material = Enum.Material.Neon
    tracer.Color = color
    tracer.CastShadow = false
    tracer.Transparency = 0
    tracer.CFrame = CFrame.new(origin, hitPosition) * CFrame.new(0, 0, -dist / 2)
    tracer.Parent = workspace

    local tween = TweenService:Create(tracer, TweenInfo.new(0.25), {Transparency = 0.7})
    tween:Play()
    Debris:AddItem(tracer, lifetime)
end

