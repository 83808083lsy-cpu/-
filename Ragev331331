-- Path clear checker (ring samples)
local function isPathClearStrict(origin, targetPos, targetCharacter, sampleRadius, sampleCount)
    sampleRadius = sampleRadius or cfg.sampleRadius
    sampleCount = sampleCount or cfg.sampleCount

    local dir = targetPos - origin
    local dist = dir.Magnitude
    if dist <= 0 then return false end
    local dirUnit = dir.Unit

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { lp.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    local centerHit = workspace:Raycast(origin, dir, rayParams)
    if centerHit then
        if not centerHit.Instance:IsDescendantOf(targetCharacter) then
            return false
        end
    end

    local upGuess = Vector3.new(0, 1, 0)
    local right = dirUnit:Cross(upGuess)
    if right.Magnitude < 1e-3 then
        upGuess = Vector3.new(1, 0, 0)
        right = dirUnit:Cross(upGuess)
    end
    right = right.Unit
    local up = right:Cross(dirUnit).Unit

    for i = 0, sampleCount - 1 do
        local angle = (i / sampleCount) * math.pi * 2
        local offset = right * (math.cos(angle) * sampleRadius) + up * (math.sin(angle) * sampleRadius)
        local sampleOrigin = origin + offset
        local sampleDir = targetPos - sampleOrigin
        if sampleDir.Magnitude > 0.001 then
            local hit = workspace:Raycast(sampleOrigin, sampleDir, rayParams)
            if hit then
                if not hit.Instance:IsDescendantOf(targetCharacter) then
                    return false
                end
            end
        end
    end

    return true
end

-- Resolve with penetration logic
local function resolveHitWithPenetration(origin, targetPos, targetCharacter)
    local dir = targetPos - origin
    local totalDist = dir.Magnitude
    if totalDist <= 0 then return nil end
    local dirUnit = dir.Unit

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { lp.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    local currentOrigin = origin
    local penetratedSum = 0
    local maxThickness = cfg.maxThickness
    local step = cfg.penetrationStep

    while true do
        local remainingDir = targetPos - currentOrigin
        if remainingDir.Magnitude <= 0.01 then
            return {hit = true, hitPosition = targetPos, hitInstance = targetCharacter:FindFirstChild("Head"), hitHumanoid = targetCharacter:FindFirstChildOfClass("Humanoid"), isHeadshot = true}
        end

        local result = workspace:Raycast(currentOrigin, remainingDir, rayParams)
        if not result then
            return {hit = true, hitPosition = targetPos, hitInstance = targetCharacter:FindFirstChild("Head"), hitHumanoid = targetCharacter:FindFirstChildOfClass("Humanoid"), isHeadshot = true}
        end

        if result.Instance and result.Instance:IsDescendantOf(targetCharacter) then
            local isHeadshot = result.Instance.Name:lower():match("head") ~= nil
            local mdl = result.Instance:FindFirstAncestorOfClass("Model")
            local hum = mdl and mdl:FindFirstChildOfClass("Humanoid") or targetCharacter:FindFirstChildOfClass("Humanoid")
            return {hit = true, hitPosition = result.Position, hitInstance = result.Instance, hitHumanoid = hum, isHeadshot = isHeadshot}
        end

        if not cfg.penetrationEnabled then
            return {hit = false, hitPosition = result.Position, hitInstance = result.Instance, hitHumanoid = nil, isHeadshot = false}
        end

        local exitFound = false
        local exitPos = nil
        local pos = result.Position + dirUnit * (step * 0.5)
        local overlapParams = OverlapParams.new()
        overlapParams.FilterDescendantsInstances = { lp.Character }
        overlapParams.FilterType = Enum.RaycastFilterType.Blacklist
        local maxSteps = math.ceil((maxThickness - penetratedSum) / step)
        if maxSteps <= 0 then
            return {hit = false, hitPosition = result.Position, hitInstance = result.Instance, hitHumanoid = nil, isHeadshot = false}
        end

        for i = 1, maxSteps do
            local parts = workspace:GetPartBoundsInRadius(pos, step * 0.4, overlapParams)
            local insideSolid = false
            if parts and #parts > 0 then
                for _, part in ipairs(parts) do
                    if part and part.CanCollide and not part:IsDescendantOf(targetCharacter) then
                        insideSolid = true
                        break
                    end
                end
            end
            if not insideSolid then
                exitFound = true
                exitPos = pos
                break
            end
            pos = pos + dirUnit * step
        end

        if not exitFound then
            return {hit = false, hitPosition = result.Position, hitInstance = result.Instance, hitHumanoid = nil, isHeadshot = false}
        end

        penetratedSum = penetratedSum + (exitPos - result.Position).Magnitude
        if penetratedSum > maxThickness then
            return {hit = false, hitPosition = result.Position, hitInstance = result.Instance, hitHumanoid = nil, isHeadshot = false}
        end

        currentOrigin = exitPos + dirUnit * 0.01
    end
end

-- auto adjust helper (vertical & side micro-adjust)
local function autoAdjustCandidate(rootPos, side, fwdOffset, initHeight, rightVec, forwardVec, leftLimit, rightLimit, overlapParams, rayParams)
    local maxExtra = cfg.autoAdjustMaxExtraUp or 8
    local stepH = cfg.autoAdjustVerticalStep or 0.5 -- 使用更细的步进以提高找到合适高度的概率
    for dh = 0, maxExtra, stepH do
        local h = initHeight + dh
        if h > 40 then break end
        local cand = rootPos + Vector3.new(0, h, 0) + rightVec * side + forwardVec * fwdOffset
        local nearby = workspace:GetPartBoundsInRadius(cand, 0.6, overlapParams)
        local insideSolid = false
        if nearby and #nearby > 0 then
            for _, part in ipairs(nearby) do
                if part and part.CanCollide then
                    insideSolid = true
                    break
                end
            end
        end
        if not insideSolid then
            local upHit = workspace:Raycast(cand, Vector3.new(0, 1.6, 0), rayParams)
            if not upHit then
                return cand, h, side
            end
        end
    end

    for dh = stepH, math.min(initHeight, 6), stepH do
        local h = initHeight - dh
        if h < 0 then break end
        local cand = rootPos + Vector3.new(0, h, 0) + rightVec * side + forwardVec * fwdOffset
        local nearby = workspace:GetPartBoundsInRadius(cand, 0.6, overlapParams)
        local insideSolid = false
        if nearby and #nearby > 0 then
            for _, part in ipairs(nearby) do
                if part and part.CanCollide then
                    insideSolid = true
                    break
                end
            end
        end
        if not insideSolid then
            local upHit = workspace:Raycast(cand, Vector3.new(0, 1.6, 0), rayParams)
            if not upHit then
                return cand, h, side
            end
        end
    end

    local maxSideAdjust = math.max(leftLimit, rightLimit)
    local stepSide = cfg.autoAdjustSideStep or 2
    for s = stepSide, maxSideAdjust, stepSide do
        local candidatesides = {}
        if side > 0 then table.insert(candidatesides, math.max(0, side - s)) end
        if side < 0 then table.insert(candidatesides, math.min(0, side + s)) end
        table.insert(candidatesides, side + s)
        table.insert(candidatesides, side - s)
        for _, newSide in ipairs(candidatesides) do
            if newSide and newSide >= -leftLimit and newSide <= rightLimit then
                for dh = 0, maxExtra, stepH do
                    local h = initHeight + dh
                    if h > 40 then break end
                    local cand = rootPos + Vector3.new(0, h, 0) + rightVec * newSide + forwardVec * fwdOffset
                    local nearby = workspace:GetPartBoundsInRadius(cand, 0.6, overlapParams)
                    local insideSolid = false
                    if nearby and #nearby > 0 then
                        for _, part in ipairs(nearby) do
                            if part and part.CanCollide then
                                insideSolid = true
                                break
                            end
                        end
                    end
                    if not insideSolid then
                        local upHit = workspace:Raycast(cand, Vector3.new(0, 1.6, 0), rayParams)
                        if not upHit then
                            return cand, h, newSide
                        end
                    end
                end
            end
        end
    end

    return nil
end

-- findClearOrigin: 优化偏移尝试顺序：优先尝试小偏移（减少不必要的大偏移），返回 origin, resolved, usedSide, usedHeight, aimOff
local function findClearOrigin(targetPlayer, height, leftOffset, rightOffset, attempts)
    attempts = attempts or cfg.attempts
    height = height or cfg.upOffset
    leftOffset = leftOffset or cfg.leftOffset
    rightOffset = rightOffset or cfg.rightOffset

    if not lp or not lp.Character then return nil end
    local root = lp.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    if not targetPlayer or not targetPlayer.Character then return nil end
    local targetHead = targetPlayer.Character:FindFirstChild("Head")
    if not targetHead then return nil end

    -- use root orientation for consistent offsets
    local forward = root.CFrame.LookVector
    local right = root.CFrame.RightVector
    local up = Vector3.new(0, 1, 0)

    local overlapParams = OverlapParams.new()
    overlapParams.FilterDescendantsInstances = { lp.Character }
    overlapParams.FilterType = Enum.RaycastFilterType.Blacklist
    overlapParams.MaxParts = 16

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { lp.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    -- 构造候选侧偏，从小到大（优先更小的偏移，减少对准误差）
    local rawSides = {
        -leftOffset * 0.25, -leftOffset * 0.5, -leftOffset * 0.75, -leftOffset,
        0,
        rightOffset * 0.25, rightOffset * 0.5, rightOffset * 0.75, rightOffset
    }
    table.sort(rawSides, function(a, b) return math.abs(a) < math.abs(b) end)

    local function tryCandidateWithAdjust(side, fwdOffset)
        local rootPos = root.Position
        local cand, usedH, usedSide = autoAdjustCandidate(rootPos, side, fwdOffset, height, right, forward, leftOffset, rightOffset, overlapParams, rayParams)
        if not cand then return false end

        local aimOffsets = {}
        table.insert(aimOffsets, Vector3.new(0, 0, 0))
        local sampleN = math.max(6, cfg.sampleCount)
        for j = 1, sampleN do
            local angle = (j / sampleN) * math.pi * 2
            local radius = cfg.hitRadius * (0.6 + 0.4 * ((j % 2)))
            local off = right * math.cos(angle) * radius + up * math.sin(angle) * radius
            table.insert(aimOffsets, off)
        end

        for _, off in ipairs(aimOffsets) do
            local aimPos = targetHead.Position + off
            local resolved = resolveHitWithPenetration(cand, aimPos, targetPlayer.Character)
            if resolved and resolved.hit then
                return true, cand, resolved, usedSide or side, usedH or height, off
            end
        end
        return false
    end

    for _, side in ipairs(rawSides) do
        local fwdOffset = 0
        local ok, candidate, resolved, usedSide, usedH, aimOff = tryCandidateWithAdjust(side, fwdOffset)
        if ok then
            return candidate, resolved, usedSide, usedH, aimOff
        end
    end

    -- biased random fallback toward edges
    for i = 1, attempts do
        local side
        if math.random() < 0.65 then
            local mag = (0.6 + 0.4 * math.random()) * (math.random() < 0.5 and leftOffset or rightOffset)
            side = (math.random() < 0.5) and -mag or mag
        else
            side = (math.random() * (leftOffset + rightOffset)) - leftOffset
            side = math.clamp(side, -leftOffset, rightOffset)
        end
        local fwdOffset = (math.random() * 2 - 1) * 5
        local ok, candidate, resolved, usedSide, usedH, aimOff = tryCandidateWithAdjust(side, fwdOffset)
        if ok then
            return candidate, resolved, usedSide, usedH, aimOff
        end
    end

    return nil
end

-- helper: 安全检测是否为好友（使用 pcall 防止异常）
local function isFriendSafe(player)
    if not lp or not player then return false end
    local ok, res = pcall(function()
        return lp:IsFriendsWith(player.UserId)
    end)
    return ok and res
end

-- target selection: nearest alive (并可跳过好友)
local function get_target()
    local target, dist = nil, math.huge
    if not lp or not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return nil end
    local originPos = lp.Character.HumanoidRootPart.Position
    for _, p in next, Players:GetPlayers() do
        if p ~= lp and p.Character then
            -- 跳过好友（若 cfg.skipFriends 打开）
            if cfg.skipFriends then
                local friend = isFriendSafe(p)
                if friend then
                    -- 跳过
                else
                    local head = p.Character:FindFirstChild("Head")
                    local hum = p.Character:FindFirstChildOfClass("Humanoid")
                    if head and hum and hum.Health > 0 then
                        local mag = (originPos - head.Position).Magnitude
                        if mag < dist then
                            dist = mag
                            target = p
                        end
                    end
                end
            else
                local head = p.Character:FindFirstChild("Head")
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                if head and hum and hum.Health > 0 then
                    local mag = (originPos - head.Position).Magnitude
                    if mag < dist then
                        dist = mag
                        target = p
                    end
                end
            end
        end
    end
    return target
end

-- Main loop
RunService.Heartbeat:Connect(function()
    if os.clock() - last_attack < cooldown then return end
    if not cfg.rageEnabled then return end
    if not lp or not lp.Character then return end
    local char = lp.Character
    local tool = char and char:FindFirstChildOfClass("Tool")
    if not char or not tool or not char:FindFirstChild("HumanoidRootPart") then return end

    local enemy = get_target()
    if enemy and enemy.Character and enemy.Character:FindFirstChild("Head") then
        -- 双重保险：若选择到的 enemy 意外地是好友（race），则再检查一次并跳过
        if cfg.skipFriends and isFriendSafe(enemy) then
            return
        end

        local head = enemy.Character.Head

        local origin, resolved, usedSide, usedHeight, aimOff = findClearOrigin(enemy, cfg.upOffset, cfg.leftOffset, cfg.rightOffset, cfg.attempts)
        if not origin or not resolved then
            return
        end

        if not resolved.hit then return end

        last_attack = os.clock()

        action_sync:FireServer({
            origin = origin,
            direction = (resolved.hitPosition - origin).Unit,
            hitPosition = resolved.hitPosition,
            hitInstance = resolved.hitInstance,
            hitHumanoid = resolved.hitHumanoid,
            IsHeadshot = resolved.isHeadshot or false
        })

        muzzle_flash:FireServer()
        fake_bullet:FireServer(CFrame.new(origin, resolved.hitPosition), (resolved.hitPosition - origin).Unit)

        -- spawnTracer 使用 cfg.tracerEnabled 来决定是否生成轨迹
        spawnTracer(origin, resolved.hitPosition, { Color = cfg.tracerColor, Thickness = cfg.tracerThickness, Lifetime = cfg.tracerLifetime })
        spawnImpactEffect(resolved.hitPosition)

        -- 更新 GUI lastInfo（格式化）
        pcall(function()
            if lastInfoLabel then
                local rootPos = char.HumanoidRootPart.Position
                local rel = origin - rootPos
                local sideVal = math.floor(rel:Dot(char.HumanoidRootPart.CFrame.RightVector) * 100 + 0.5) / 100
                local upVal   = math.floor(rel.Y * 100 + 0.5) / 100
                local fwdVal  = math.floor(rel:Dot(char.HumanoidRootPart.CFrame.LookVector) * 100 + 0.5) / 100
                local hp = resolved.hitPosition
                lastInfoLabel.Text = string.format("Last Offset -> side: %d  up: %d  fwd: %d\nLast HitPos -> (%.1f, %.1f, %.1f)\nTracer: %s  SkipFriends: %s",
                    math.floor(sideVal+0.5), math.floor(upVal+0.5), math.floor(fwdVal+0.5), hp.X, hp.Y, hp.Z, (cfg.tracerEnabled and "ON" or "OFF"), (cfg.skipFriends and "ON" or "OFF"))
            end
        end)
    end
end)
