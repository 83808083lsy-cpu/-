local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local ENABLE_VISUALS = true
local TEAM_CHECK_DISABLED = false

local DEFAULT_SCAN_INTERVAL = 0.05
local RAGE_SCAN_INTERVAL = 0.02

local TRACER_DURATION = 20.0
local TRACER_THICKNESS = 0.08
local TRACER_COLOR = Color3.fromRGB(255, 105, 180)
local MARKER_DURATION = 20.0
local MARKER_SIZE = 0.28
local MARKER_COLOR = Color3.fromRGB(255, 255, 0)

local OFFMAP_SPAWN_ENABLED = true
local SEARCH_ATTEMPTS = 300
local SEARCH_ATTEMPTS_RAGE = 800
local SEARCH_HEIGHT = 20
local SPAWN_VERTICAL_OFFSET = 19

local SEARCH_WORLD_MIN = Vector2.new(-500, -500)
local SEARCH_WORLD_MAX = Vector2.new(500, 500)
local EDGE_GRID_STEPS = 6

local MAX_ATTACK_DISTANCE_DEFAULT = 100
local MAX_ATTACK_DISTANCE_MAX = 1000
local maxAttackDistance = MAX_ATTACK_DISTANCE_DEFAULT

local ALLOW_DETECT_BEHIND_WALLS = false
local rageEnabled = false
local wallCheckEnabled = ALLOW_DETECT_BEHIND_WALLS
local currentScanInterval = DEFAULT_SCAN_INTERVAL

math.randomseed(tick() % 2^31)

local function clamp(val, a, b)
    if val < a then return a end
    if val > b then return b end
    return val
end

local function GetDefaultRaycastParams()
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = { LocalPlayer.Character, workspace.CurrentCamera }
    return params
end

local function IsShielded(char)
    if not char then return false end
    if char:FindFirstChildOfClass("ForceField") then return true end
    local shieldObj = char:FindFirstChild("Shield")
    if shieldObj and shieldObj:IsA("BoolValue") and shieldObj.Value then return true end
    if char.GetAttribute then
        local attr = char:GetAttribute("Shielded")
        if attr == true then return true end
    end
    return false
end

local function IsVisible(targetPart, fromPos)
    if not targetPart or not fromPos then return false end
    local params = GetDefaultRaycastParams()
    local dir = targetPart.Position - fromPos
    local result = workspace:Raycast(fromPos, dir, params)
    if result and result.Instance and result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

local function HasClearLineToTarget(spawnPos, targetPart)
    if not spawnPos or not targetPart then return false end
    local params = GetDefaultRaycastParams()
    local dir = targetPart.Position - spawnPos
    if dir.Magnitude < 0.1 then return true end
    local res = workspace:Raycast(spawnPos, dir, params)
    if res and res.Instance then
        if res.Instance:IsDescendantOf(targetPart.Parent) then
            return true
        else
            return false
        end
    end
    return false
end

local function SpawnTracer(startPos, endPos)
    if not ENABLE_VISUALS then return end
    if not startPos or not endPos then return end
    local dir = endPos - startPos
    local dist = dir.Magnitude
    if dist <= 0 then return end

    local part = Instance.new("Part")
    part.Name = "TracerPart"
    part.Anchored = true
    part.CanCollide = false
    part.Material = Enum.Material.Neon
    part.Color = TRACER_COLOR
    part.TopSurface = Enum.SurfaceType.Smooth
    part.BottomSurface = Enum.SurfaceType.Smooth
    part.Size = Vector3.new(TRACER_THICKNESS, TRACER_THICKNESS, math.max(dist, 0.01))
    part.CFrame = CFrame.new(startPos, endPos) * CFrame.new(0, 0, -dist / 2)
    part.CastShadow = false
    part.Transparency = 0
    part.Parent = workspace

    local tweenInfo = TweenInfo.new(TRACER_DURATION, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(part, tweenInfo, { Transparency = 1 })
    tween:Play()
    delay(TRACER_DURATION + 0.02, function()
        if part and part.Parent then part:Destroy() end
    end)
end

local function SpawnHitMarker(pos)
    if not ENABLE_VISUALS then return end
    if not pos then return end
    local marker = Instance.new("Part")
    marker.Name = "HitMarker"
    marker.Shape = Enum.PartType.Ball
    marker.Size = Vector3.new(MARKER_SIZE, MARKER_SIZE, MARKER_SIZE)
    marker.Anchored = true
    marker.CanCollide = false
    marker.Material = Enum.Material.Neon
    marker.Color = MARKER_COLOR
    marker.CFrame = CFrame.new(pos)
    marker.Transparency = 0
    marker.Parent = workspace

    local tween = TweenService:Create(marker, TweenInfo.new(MARKER_DURATION, Enum.EasingStyle.Linear), { Transparency = 1, Size = Vector3.new(0.01, 0.01, 0.01) })
    tween:Play()
    delay(MARKER_DURATION + 0.02, function()
        if marker and marker.Parent then marker:Destroy() end
    end)
end

local function GroundPointAtXZ(x, z, height)
    local origin = Vector3.new(x, height, z)
    local params = GetDefaultRaycastParams()
    local res = workspace:Raycast(origin, Vector3.new(0, -height - 50, 0), params)
    if res then
        return res.Position, res.Normal, res.Instance
    end
    return nil
end

local function GenerateLocalCandidatePoints(centerX, centerZ, radius, edgeSteps)
    local pts = {}
    local radiLayers = {0.9, 0.7, 0.5, 0.3}
    for _, rf in ipairs(radiLayers) do
        local r = clamp(radius * rf, 1, radius)
        for i = 0, edgeSteps - 1 do
            local angle = (i / edgeSteps) * math.pi * 2
            local x = centerX + math.cos(angle) * r
            local z = centerZ + math.sin(angle) * r
            table.insert(pts, Vector2.new(x, z))
        end
    end
    return pts
end

local function FindSpawnPositionForTarget_Local(targetPart, maxAttempts, localRadius)
    if not targetPart or not LocalPlayer.Character then return nil end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local px, pz = hrp.Position.X, hrp.Position.Z

    local attempts = 0
    local candidates = GenerateLocalCandidatePoints(px, pz, localRadius, EDGE_GRID_STEPS)
    for _, v in ipairs(candidates) do
        if attempts >= maxAttempts then break end
        attempts = attempts + 1
        local gx, gz = v.X, v.Y
        local groundPos = GroundPointAtXZ(gx, gz, SEARCH_HEIGHT)
        if groundPos then
            local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
            if (spawnPos - hrp.Position).Magnitude <= localRadius then
                if HasClearLineToTarget(spawnPos, targetPart) then
                    return spawnPos
                end
            end
        end
    end

    local remaining = maxAttempts - attempts
    for i = 1, remaining do
        local theta = math.random() * math.pi * 2
        local r = math.sqrt(math.random()) * localRadius
        local rx = px + math.cos(theta) * r
        local rz = pz + math.sin(theta) * r
        local groundPos = GroundPointAtXZ(rx, rz, SEARCH_HEIGHT)
        if groundPos then
            local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
            if (spawnPos - hrp.Position).Magnitude <= localRadius then
                if HasClearLineToTarget(spawnPos, targetPart) then
                    return spawnPos
                end
            end
        end
    end

    return nil
end

local function FindSpawnPositionForTarget_Global(targetPart, maxAttempts)
    local attempts = 0
    local function globalCandidates()
        local pts = {}
        table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X, SEARCH_WORLD_MIN.Y))
        table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X, SEARCH_WORLD_MAX.Y))
        table.insert(pts, Vector2.new(SEARCH_WORLD_MAX.X, SEARCH_WORLD_MIN.Y))
        table.insert(pts, Vector2.new(SEARCH_WORLD_MAX.X, SEARCH_WORLD_MAX.Y))
        for i = 0, EDGE_GRID_STEPS do
            local t = i / math.max(1, EDGE_GRID_STEPS)
            table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X + (SEARCH_WORLD_MAX.X - SEARCH_WORLD_MIN.X) * t, SEARCH_WORLD_MIN.Y))
            table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X + (SEARCH_WORLD_MAX.X - SEARCH_WORLD_MIN.X) * t, SEARCH_WORLD_MAX.Y))
            table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X, SEARCH_WORLD_MIN.Y + (SEARCH_WORLD_MAX.Y - SEARCH_WORLD_MIN.Y) * t))
            table.insert(pts, Vector2.new(SEARCH_WORLD_MAX.X, SEARCH_WORLD_MIN.Y + (SEARCH_WORLD_MAX.Y - SEARCH_WORLD_MIN.Y) * t))
        end
        return pts
    end

    for _, v in ipairs(globalCandidates()) do
        if attempts >= maxAttempts then break end
        attempts = attempts + 1
        local gx, gz = v.X, v.Y
        local groundPos = GroundPointAtXZ(gx, gz, SEARCH_HEIGHT)
        if groundPos then
            local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
            if HasClearLineToTarget(spawnPos, targetPart) then
                return spawnPos
            end
        end
    end

    local remaining = maxAttempts - attempts
    for i = 1, remaining do
        local rx = math.random() * (SEARCH_WORLD_MAX.X - SEARCH_WORLD_MIN.X) + SEARCH_WORLD_MIN.X
        local rz = math.random() * (SEARCH_WORLD_MAX.Y - SEARCH_WORLD_MIN.Y) + SEARCH_WORLD_MIN.Y
        local groundPos = GroundPointAtXZ(rx, rz, SEARCH_HEIGHT)
        if groundPos then
            local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
            if HasClearLineToTarget(spawnPos, targetPart) then
                return spawnPos
            end
        end
    end

    return nil
end

