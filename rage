            end
            local t = (displayVal - minVal) / math.max(1, (maxVal - minVal))
            sliderFill.Size = UDim2.new(t, 0, 1, 0)
            local px = t * (sliderBar.AbsoluteSize.X - knob.AbsoluteSize.X)
            knob.Position = UDim2.new(0, px, 0, -1)
            label.Text = labelText.." : "..tostring(displayVal)
            if onChange then
                onChange(displayVal)
            end
        end

        setValue(initialVal)

        local dragging = false
        local function updateValueFromInput(x)
            local abs = sliderBar.AbsolutePosition
            local width = sliderBar.AbsoluteSize.X
            local localX = x - abs.X
            local t = localX / math.max(1, width)
            t = clamp(t, 0, 1)
            local val = minVal + t * (maxVal - minVal)
            setValue(val)
        end

        knob.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)

        sliderBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                updateValueFromInput(input.Position.X)
                dragging = true
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                updateValueFromInput(input.Position.X)
            end
        end)

        return {
            label = label,
            bar = sliderBar,
            fill = sliderFill,
            knob = knob,
            setValue = setValue,
        }
    end

