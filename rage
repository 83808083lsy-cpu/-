    rageBtn.Font = Enum.Font.SourceSansSemibold
    rageBtn.TextSize = 14
    rageBtn.TextColor3 = Color3.fromRGB(255,255,255)
    rageBtn.BackgroundColor3 = Color3.fromRGB(120, 20, 20)
    rageBtn.Parent = frame

    local wallBtn = Instance.new("TextButton")
    wallBtn.Name = "WallBtn"
