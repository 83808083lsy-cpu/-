    local sliderLabel = Instance.new("TextLabel")
    sliderLabel.Name = "SliderLabel"
    sliderLabel.Size = UDim2.new(0, 240, 0, 18)
    sliderLabel.Position = UDim2.new(0, 8, 0, 64)
    sliderLabel.BackgroundTransparency = 1
    sliderLabel.Text = "Max Distance: "..tostring(maxAttackDistance)
    sliderLabel.TextColor3 = Color3.fromRGB(220,220,220)
    sliderLabel.Font = Enum.Font.SourceSans
    sliderLabel.TextSize = 14
    sliderLabel.TextXAlignment = Enum.TextXAlignment.Left
    sliderLabel.Parent = frame

    local sliderBar = Instance.new("Frame")
    sliderBar.Name = "SliderBar"
    sliderBar.Size = UDim2.new(0, 240, 0, 12)
    sliderBar.Position = UDim2.new(0, 8, 0, 84)
    sliderBar.BackgroundColor3 = Color3.fromRGB(60,60,60)
    sliderBar.BorderSizePixel = 0
    sliderBar.Parent = frame

    local sliderFill = Instance.new("Frame")
    sliderFill.Name = "SliderFill"
    sliderFill.Size = UDim2.new(maxAttackDistance / MAX_ATTACK_DISTANCE_MAX, 0, 1, 0)
    sliderFill.Position = UDim2.new(0, 0, 0, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(200,100,20)
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBar

    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.Parent = sliderBar

    sliderBar:GetPropertyChangedSignal("AbsoluteSize"):Wait()
    knob:GetPropertyChangedSignal("AbsoluteSize"):Wait()

    local function SetSliderValue(val)
        val = clamp(val, 0, MAX_ATTACK_DISTANCE_MAX)
        maxAttackDistance = math.floor(val + 0.5)
        sliderLabel.Text = "Max Distance: "..tostring(maxAttackDistance)
        local t = maxAttackDistance / MAX_ATTACK_DISTANCE_MAX
        sliderFill.Size = UDim2.new(t, 0, 1, 0)
        local px = t * (sliderBar.AbsoluteSize.X - knob.AbsoluteSize.X)
        knob.Position = UDim2.new(0, px, 0, -2)
    end

    SetSliderValue(maxAttackDistance)

    local dragging = false
    local function updateValueFromInput(x)
        local abs = sliderBar.AbsolutePosition
        local width = sliderBar.AbsoluteSize.X
        local localX = x - abs.X
        local t = localX / math.max(1, width)
        t = clamp(t, 0, 1)
        SetSliderValue(t * MAX_ATTACK_DISTANCE_MAX)
    end

    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    sliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            updateValueFromInput(input.Position.X)
            dragging = true
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateValueFromInput(input.Position.X)
        end
    end)

    rageBtn.MouseButton1Click:Connect(function()
        rageEnabled = not rageEnabled
        if rageEnabled then
            rageBtn.Text = "Rage: ON"
            rageBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
            OFFMAP_SPAWN_ENABLED = true
            currentScanInterval = RAGE_SCAN_INTERVAL
            SEARCH_ATTEMPTS = SEARCH_ATTEMPTS_RAGE
        else
            rageBtn.Text = "Rage: OFF"
            rageBtn.BackgroundColor3 = Color3.fromRGB(120, 20, 20)
            OFFMAP_SPAWN_ENABLED = true
            currentScanInterval = DEFAULT_SCAN_INTERVAL
            SEARCH_ATTEMPTS = 300
        end
    end)

    wallBtn.MouseButton1Click:Connect(function()
        wallCheckEnabled = not wallCheckEnabled
        ALLOW_DETECT_BEHIND_WALLS = wallCheckEnabled
        if wallCheckEnabled then
            wallBtn.Text = "Wall: ON"
            wallBtn.BackgroundColor3 = Color3.fromRGB(40, 160, 40)
        else
            wallBtn.Text = "Wall: OFF"
            wallBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        end
    end)

    local draggingFrame = false
    local dragStart, startPos = nil, nil
    local function onInputBegan(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingFrame = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    draggingFrame = false
                end
            end)
        end
    end
    local function onInputChanged(input)
        if not draggingFrame or not dragStart or not startPos then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            local newX = startPos.X.Offset + delta.X
            local newY = startPos.Y.Offset + delta.Y
            local screenX, screenY = workspace.CurrentCamera.ViewportSize.X, workspace.CurrentCamera.ViewportSize.Y
            newX = clamp(newX, 0, screenX - frame.AbsoluteSize.X)
            newY = clamp(newY, 0, screenY - frame.AbsoluteSize.Y)
            frame.Position = UDim2.new(0, newX, 0, newY)
        end
    end
    frame.InputBegan:Connect(onInputBegan)
    UserInputService.InputChanged:Connect(onInputChanged)
end

