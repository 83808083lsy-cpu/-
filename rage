task.spawn(function()
    while true do
        task.wait(currentScanInterval)

        if not LocalPlayer or not LocalPlayer.Character then
        else
            local cam = workspace.CurrentCamera
            if not cam then
            else
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if not tool then
                else
                    local fireRemote = tool:FindFirstChild("FireWeapon")
                    local hitRemote = tool:FindFirstChild("GunHit")
                    if not fireRemote or not hitRemote then
                    else
                        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if not hrp then
                        else
                            local candidates = {}
                            local camPos = cam.CFrame.Position

                            -- 遍历 workspace 中的 Humanoid（仅一次），收集候选
                            for _, desc in pairs(workspace:GetDescendants()) do
                                if desc:IsA("Humanoid") and desc.Health > 0 and desc.Parent ~= LocalPlayer.Character then
                                    local char = desc.Parent
                                    if IsShielded(char) then
                                        -- 被护盾的跳过（循环直接跳过）
                                    else
                                        local targetPart = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                                        if targetPart then
                                            local playerFromChar = Players:GetPlayerFromCharacter(char)
                                            local skipForTeam = false
                                            if playerFromChar and TEAM_CHECK_DISABLED then
                                                if not (LocalPlayer.Neutral or playerFromChar.Team ~= LocalPlayer.Team) then
                                                    skipForTeam = true
                                                end
                                            end
                                            if not skipForTeam then
                                                local distToPlayer = (targetPart.Position - hrp.Position).Magnitude
                                                if distToPlayer <= maxAttackDistance then
                                                    local visible = IsVisible(targetPart, camPos)
                                                    table.insert(candidates, {h = desc, p = char, head = targetPart, dist = distToPlayer, visible = visible})
                                                end
                                            end
                                        end
                                    end
                                end
                            end

                            -- 从候选中选出最优目标（基于 PRIORITIZE_NEARBY 开关）
                            local best = nil
                            local bestScore = math.huge
                            for _, c in ipairs(candidates) do
                                local score = c.dist
                                if PRIORITIZE_NEARBY then
                                    -- 纯距离优先（可见不改变主排序，但仍可作为 tie-breaker）
                                    if c.visible then score = score * 0.95 end
                                else
                                    -- 可见性加权：可见目标折扣，隐蔽目标加重
                                    if c.visible then
                                        score = score * 0.6
                                    else
                                        score = score * 1.2
                                    end
                                end
                                if score < bestScore then
                                    bestScore = score
                                    best = c
                                end
                            end

                            local targetWasBehind = false

                            if DISABLE_WALL_CHECKS_MODE then
                                -- 关闭墙壁检查模式：仍然使用 best（可能是不可见），并假定墙后
                                if best then
                                    targetWasBehind = true
                                end
                            else
                                -- 如果选出的 best 是不可见且允许检测墙后，则标记为墙后
                                if best and not best.visible and ALLOW_DETECT_BEHIND_WALLS then
                                    targetWasBehind = true
                                else
                                    targetWasBehind = false
                                end
                            end

                            if best then
                                -- 额外护盾检查（动态护盾状态也会被跳过）
                                if IsShielded(best.p) then
                                    -- 跳过被护盾的目标
                                else
                                    local headPos = best.head.Position
                                    local tstamp = tick()
                                    local processed = false

                                    -- 先尝试找到 spawnPos（本地 -> 全局）
                                    local spawnPos, spawnGroundY = nil, nil
                                    if OFFMAP_SPAWN_ENABLED then
                                        spawnPos, spawnGroundY = FindSpawnPositionForTarget_Local(best.head, SEARCH_ATTEMPTS, maxAttackDistance)
                                        if not spawnPos then
                                            spawnPos, spawnGroundY = FindSpawnPositionForTarget_Global(best.head, math.floor(SEARCH_ATTEMPTS / 2))
                                        end
                                    end

                                    -- 若无 spawnPos 并且目标被墙遮挡或关闭墙壁检查模式，使用改进后的四向/多角偏移扫描（更密集）
                                    if not spawnPos and OFFMAP_SPAWN_ENABLED then
                                        local tryOffset = (targetWasBehind or DISABLE_WALL_CHECKS_MODE)
                                        if tryOffset then
                                            local altPos, altGroundY = FindSpawnPositionAroundTargetOffsets(best.head, OFFMAP_TARGET_OFFSET, 12)
                                            if altPos then
                                                spawnPos = altPos
                                                spawnGroundY = altGroundY
                                            end
                                        end
                                    end

                                    -- 选择实际命中部位（随机头或躯干），并计算实际命中位置（考虑 HIT_RADIUS）
                                    local headPart = best.p:FindFirstChild("Head")
                                    local hrpPart = best.p:FindFirstChild("HumanoidRootPart")
                                    local chosenPart = headPart or hrpPart
                                    if headPart and hrpPart then
                                        if RANDOMIZE_HEAD_BODY then
                                            if math.random() < HEAD_HIT_PROB then
                                                chosenPart = headPart
                                            else
                                                chosenPart = hrpPart
                                            end
                                        else
                                            -- 不随机：始终头部（若存在）
                                            chosenPart = headPart or hrpPart
                                        end
                                    end
                                    if not chosenPart then
                                        -- 没有可用的命中部位，跳过本次目标
                                    else
                                        local actualHitPos = chosenPart.Position
                                        if HIT_RADIUS and HIT_RADIUS > 0 then
                                            actualHitPos = actualHitPos + RandomVectorInSphere(HIT_RADIUS)
                                        end

                                        -- 优化：如果目标在墙后且不允许穿墙，尝试在 HIT_RADIUS 内采样找可见采样点（优先 spawnPos，再 camera）
                                        local foundSample = nil
                                        if targetWasBehind and (not ALLOW_SHOOT_THROUGH_WALLS) and HIT_RADIUS and HIT_RADIUS > 0 then
                                            local origins = {}
                                            if spawnPos then table.insert(origins, spawnPos) end
                                            table.insert(origins, camPos)
                                            for _, origin in ipairs(origins) do
                                                for i = 1, SAMPLE_HIT_CHECKS do
                                                    local samplePos = chosenPart.Position + RandomVectorInSphere(HIT_RADIUS)
                                                    if IsPointVisibleFrom(origin, samplePos, best.p) then
                                                        foundSample = {origin = origin, pos = samplePos}
                                                        break
                                                    end
                                                end
                                                if foundSample then break end
                                            end
                                        end

                                        -- 如果在采样中找到了可用点，直接使用该 origin 发射（优先 spawnPos）
                                        if foundSample then
                                            local origin = foundSample.origin
                                            local samplePos = foundSample.pos
                                            if origin == spawnPos then
                                                local spawnDist = (spawnPos - hrp.Position).Magnitude
                                                if spawnDist <= maxAttackDistance and spawnDist <= LOCAL_SPAWN_DISTANCE_LIMIT then
                                                    local distance = (samplePos - spawnPos).Magnitude
                                                    pcall(function() fireRemote:FireServer(tstamp) end)
                                                    pcall(function()
                                                        hitRemote:FireServer(tstamp, {
                                                            {
                                                                ["Normal"] = Vector3.new(0,1,0),
                                                                ["Position"] = samplePos,
                                                                ["Instance"] = chosenPart,
                                                                ["Material"] = Enum.Material.Plastic,
                                                                ["Distance"] = distance
                                                            }
                                                        })
                                                    end)
                                                    pcall(function()
                                                        SpawnTracer(spawnPos, samplePos)
                                                        SpawnHitMarker(samplePos)
                                                    end)
                                                    processed = true
                                                end
                                            else
                                                -- origin 为 camera
                                                local distanceCam = (samplePos - camPos).Magnitude
                                                pcall(function() fireRemote:FireServer(tstamp) end)
                                                pcall(function()
                                                    hitRemote:FireServer(tstamp, {
                                                        {
                                                            ["Normal"] = Vector3.new(0,1,0),
                                                            ["Position"] = samplePos,
                                                            ["Instance"] = chosenPart,
                                                            ["Material"] = Enum.Material.Plastic,
                                                            ["Distance"] = distanceCam
                                                        }
                                                    })
                                                end)
                                                pcall(function()
                                                    SpawnTracer(camPos, samplePos)
                                                    SpawnHitMarker(samplePos)
                                                end)
                                                processed = true
                                            end
                                        else
                                            -- 新行为：当 DISABLE_WALL_CHECKS_MODE 开启时，优先且仅从找到的 spawnPos 发射（避免直接从摄像机对着墙射击）
                                            if DISABLE_WALL_CHECKS_MODE then
                                                if spawnPos then
                                                    local spawnDist = (spawnPos - hrp.Position).Magnitude
                                                    if spawnDist <= maxAttackDistance and spawnDist <= LOCAL_SPAWN_DISTANCE_LIMIT then
                                                        local distance = (actualHitPos - spawnPos).Magnitude
                                                        pcall(function() fireRemote:FireServer(tstamp) end)
                                                        pcall(function()
                                                            hitRemote:FireServer(tstamp, {
                                                                {
                                                                    ["Normal"] = Vector3.new(0,1,0),
                                                                    ["Position"] = actualHitPos,
                                                                    ["Instance"] = chosenPart,
                                                                    ["Material"] = Enum.Material.Plastic,
                                                                    ["Distance"] = distance
                                                                }
                                                            })
                                                        end)
                                                        pcall(function()
                                                            SpawnTracer(spawnPos, actualHitPos)
                                                            SpawnHitMarker(actualHitPos)
                                                        end)
                                                        processed = true
                                                    end
                                                end
                                                -- 如果没有找到 spawnPos，我们选择不盲目用摄像机射击（避免“光对着墙射击”）。
                                                -- processed 为 false -> 将跳过该目标本轮发射。
                                            else
                                                -- 旧逻辑（保留保守规则与穿透控制）
                                                local skipOffmapBecauseRule = false
                                                if targetWasBehind and (not ALLOW_SHOOT_THROUGH_WALLS) and spawnPos and spawnGroundY then
                                                    local spawnDist = (spawnPos - hrp.Position).Magnitude
                                                    if math.abs(spawnGroundY - SEARCH_HEIGHT) <= 0.5 or spawnDist <= LOCAL_SPAWN_DISTANCE_LIMIT then
                                                        skipOffmapBecauseRule = true
                                                    end
                                                end

                                                -- 只有在 OFFMAP_SPAWN_ENABLED 并且（目标不是墙后 或 允许穿透）并且没有被保守规则强制跳过时，才使用 offmap spawn 命中
                                                if spawnPos and OFFMAP_SPAWN_ENABLED and (not targetWasBehind or ALLOW_SHOOT_THROUGH_WALLS) and (not skipOffmapBecauseRule) then
                                                    local allowByThickness = true
                                                    -- 如果目标在墙后且启用穿墙，则估算墙体厚度判断是否允许穿透（简单估算：两次反向 raycast）
                                                    if targetWasBehind and ALLOW_SHOOT_THROUGH_WALLS then
                                                        local params = GetDefaultRaycastParams()
                                                        local dir = chosenPart.Position - spawnPos
                                                        if dir.Magnitude > 0.1 then
                                                            local res1 = workspace:Raycast(spawnPos, dir, params)
                                                            local res2 = workspace:Raycast(chosenPart.Position, -dir, params)
                                                            if res1 and res2 and res1.Instance and res2.Instance and res1.Instance == res2.Instance then
                                                                local thickness = (res2.Position - res1.Position).Magnitude
                                                                if thickness > WALL_THICKNESS then
                                                                    allowByThickness = false
                                                                end
                                                            end
                                                        end
                                                    end

                                                    if allowByThickness then
                                                        local spawnDist = (spawnPos - hrp.Position).Magnitude
                                                        if spawnDist <= maxAttackDistance and spawnDist <= LOCAL_SPAWN_DISTANCE_LIMIT then
                                                            local distance = (actualHitPos - spawnPos).Magnitude
                                                            pcall(function() fireRemote:FireServer(tstamp) end)
                                                            pcall(function()
                                                                hitRemote:FireServer(tstamp, {
                                                                    {
                                                                        ["Normal"] = Vector3.new(0,1,0),
                                                                        ["Position"] = actualHitPos,
                                                                        ["Instance"] = chosenPart,
                                                                        ["Material"] = Enum.Material.Plastic,
                                                                        ["Distance"] = distance
                                                                    }
                                                                })
                                                            end)
                                                            pcall(function()
                                                                SpawnTracer(spawnPos, actualHitPos)
                                                                SpawnHitMarker(actualHitPos)
                                                            end)
                                                            processed = true
                                                        end
                                                    end
                                                end

                                                -- 未处理（包括：没有 spawn、或 spawn 被保守规则跳过、或目标墙后但不允许穿透）时，使用摄像机原点发射（不会穿墙）
                                                if not processed then
                                                    local camPos2 = cam.CFrame.Position
                                                    local distanceCam = (actualHitPos - camPos2).Magnitude
                                                    pcall(function() fireRemote:FireServer(tstamp) end)
                                                    pcall(function()
                                                        hitRemote:FireServer(tstamp, {
                                                            {
                                                                ["Normal"] = Vector3.new(0,1,0),
                                                                ["Position"] = actualHitPos,
                                                                ["Instance"] = chosenPart,
                                                                ["Material"] = Enum.Material.Plastic,
                                                                ["Distance"] = distanceCam
                                                            }
                                                        })
                                                    end)
                                                    pcall(function()
                                                        SpawnTracer(camPos2, actualHitPos)
                                                        SpawnHitMarker(actualHitPos)
                                                    end)
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)
