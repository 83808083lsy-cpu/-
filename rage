local function GroundPointAtXZ(x, z, height)
    local origin = Vector3.new(x, height, z)
    local params = GetDefaultRaycastParams()
    local res = workspace:Raycast(origin, Vector3.new(0, -height - 50, 0), params)
    if res then
        return res.Position, res.Normal, res.Instance
    end
    return nil
end

local function GenerateLocalCandidatePoints(centerX, centerZ, radius, edgeSteps)
    local pts = {}
    local radiLayers = {0.9, 0.7, 0.5, 0.3}
    for _, rf in ipairs(radiLayers) do
        local r = clamp(radius * rf, 1, radius)
        for i = 0, edgeSteps - 1 do
            local angle = (i / edgeSteps) * math.pi * 2
            local x = centerX + math.cos(angle) * r
            local z = centerZ + math.sin(angle) * r
            table.insert(pts, Vector2.new(x, z))
        end
    end
    return pts
end

-- 返回 spawnPos, groundY
local function FindSpawnPositionForTarget_Local(targetPart, maxAttempts, localRadius)
    if not targetPart or not LocalPlayer.Character then return nil, nil end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil end
    local px, pz = hrp.Position.X, hrp.Position.Z

    -- 限制本地搜索半径为 LOCAL_SPAWN_DISTANCE_LIMIT（用户要求）
    localRadius = math.min(localRadius or 0, LOCAL_SPAWN_DISTANCE_LIMIT)

    local attempts = 0
    local candidates = GenerateLocalCandidatePoints(px, pz, localRadius, EDGE_GRID_STEPS)
    for _, v in ipairs(candidates) do
        if attempts >= maxAttempts then break end
        attempts = attempts + 1
        local gx, gz = v.X, v.Y
        local groundPos = GroundPointAtXZ(gx, gz, SEARCH_HEIGHT)
        if groundPos then
            local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
            if (spawnPos - hrp.Position).Magnitude <= localRadius then
                if HasClearLineToTarget(spawnPos, targetPart) then
                    return spawnPos, groundPos.Y
                end
            end
        end
    end

    local remaining = maxAttempts - attempts
    for i = 1, remaining do
        local theta = math.random() * math.pi * 2
        local r = math.sqrt(math.random()) * localRadius
        local rx = px + math.cos(theta) * r
        local rz = pz + math.sin(theta) * r
        local groundPos = GroundPointAtXZ(rx, rz, SEARCH_HEIGHT)
        if groundPos then
            local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
            if (spawnPos - hrp.Position).Magnitude <= localRadius then
                if HasClearLineToTarget(spawnPos, targetPart) then
                    return spawnPos, groundPos.Y
                end
            end
        end
    end

    return nil, nil
end

-- 返回 spawnPos, groundY
local function FindSpawnPositionForTarget_Global(targetPart, maxAttempts)
    local attempts = 0
    local function globalCandidates()
        local pts = {}
        table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X, SEARCH_WORLD_MIN.Y))
        table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X, SEARCH_WORLD_MAX.Y))
        table.insert(pts, Vector2.new(SEARCH_WORLD_MAX.X, SEARCH_WORLD_MIN.Y))
        table.insert(pts, Vector2.new(SEARCH_WORLD_MAX.X, SEARCH_WORLD_MAX.Y))
        for i = 0, EDGE_GRID_STEPS do
            local t = i / math.max(1, EDGE_GRID_STEPS)
            table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X + (SEARCH_WORLD_MAX.X - SEARCH_WORLD_MIN.X) * t, SEARCH_WORLD_MIN.Y))
            table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X + (SEARCH_WORLD_MAX.X - SEARCH_WORLD_MIN.X) * t, SEARCH_WORLD_MAX.Y))
            table.insert(pts, Vector2.new(SEARCH_WORLD_MIN.X, SEARCH_WORLD_MIN.Y + (SEARCH_WORLD_MAX.Y - SEARCH_WORLD_MIN.Y) * t))
            table.insert(pts, Vector2.new(SEARCH_WORLD_MAX.X, SEARCH_WORLD_MIN.Y + (SEARCH_WORLD_MAX.Y - SEARCH_WORLD_MIN.Y) * t))
        end
        return pts
    end

    for _, v in ipairs(globalCandidates()) do
        if attempts >= maxAttempts then break end
        attempts = attempts + 1
        local gx, gz = v.X, v.Y
        local groundPos = GroundPointAtXZ(gx, gz, SEARCH_HEIGHT)
        if groundPos then
            local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
            if HasClearLineToTarget(spawnPos, targetPart) then
                return spawnPos, groundPos.Y
            end
        end
    end

    local remaining = maxAttempts - attempts
    for i = 1, remaining do
        local rx = math.random() * (SEARCH_WORLD_MAX.X - SEARCH_WORLD_MIN.X) + SEARCH_WORLD_MIN.X
        local rz = math.random() * (SEARCH_WORLD_MAX.Y - SEARCH_WORLD_MIN.Y) + SEARCH_WORLD_MIN.Y
        local groundPos = GroundPointAtXZ(rx, rz, SEARCH_HEIGHT)
        if groundPos then
            local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
            if HasClearLineToTarget(spawnPos, targetPart) then
                return spawnPos, groundPos.Y
            end
        end
    end

    return nil, nil
end

-- 改进版：返回 spawnPos, groundY（或 nil, nil）
-- 扩展采样角度与步距，按评分选最优 spawn，修复左右采样稀少问题
local function FindSpawnPositionAroundTargetOffsets(targetPart, offsetDist, maxAttempts)
    if not targetPart then return nil, nil end
    local headPos = targetPart.Position
    -- 配置：角度数与步距数（可调整）
    local anglesCount = 8 -- 八方向采样（包括左右与对角）
    local radiusSteps = 3 -- 每个方向 3 步（从近到远）
    local attempts = 0
    local best = nil
    local bestScore = math.huge

    local hrp = nil
    if LocalPlayer and LocalPlayer.Character then
        hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    end

    for step = 1, radiusSteps do
        local rFrac = step / radiusSteps
        local r = offsetDist * rFrac
        for i = 0, anglesCount - 1 do
            if attempts >= maxAttempts then break end
            attempts = attempts + 1
            local angle = (i / anglesCount) * math.pi * 2
            local gx = headPos.X + math.cos(angle) * r
            local gz = headPos.Z + math.sin(angle) * r
            local groundPos = GroundPointAtXZ(gx, gz, SEARCH_HEIGHT)
            if groundPos then
                local spawnPos = groundPos + Vector3.new(0, SPAWN_VERTICAL_OFFSET, 0)
                if HasClearLineToTarget(spawnPos, targetPart) then
                    -- 计算评分：优先更近的 spawn（到本地 hrp），并微量偏好地面更高的点（减分）
                    local spawnDist = hrp and (spawnPos - hrp.Position).Magnitude or r
                    local heightBias = (groundPos.Y - SEARCH_HEIGHT) * -0.1 -- 地面越高 bias 越负（更优）
                    local score = spawnDist + heightBias
                    if score < bestScore then
                        bestScore = score
                        best = {pos = spawnPos, groundY = groundPos.Y, dist = spawnDist}
                    end
                end
            end
        end
        if attempts >= maxAttempts then break end
    end

    if best then
        return best.pos, best.groundY
    end
    return nil, nil
end

