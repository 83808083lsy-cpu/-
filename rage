                                            if not skipForTeam then
                                                local distToPlayer = (targetPart.Position - hrp.Position).Magnitude
                                                if distToPlayer <= maxAttackDistance and distToPlayer < bestDist and IsVisible(targetPart, camPos) then
                                                    bestDist = distToPlayer
                                                    best = {h = desc, p = char, head = targetPart}
                                                end
                                            end
                                        end
                                    end
                                end
                            end

                            if not best and ALLOW_DETECT_BEHIND_WALLS then
                                local best2 = nil
                                local bestDist2 = math.huge
                                for _, desc in pairs(workspace:GetDescendants()) do
                                    if desc:IsA("Humanoid") and desc.Health > 0 and desc.Parent ~= LocalPlayer.Character then
                                        local char = desc.Parent
                                        if IsShielded(char) then
