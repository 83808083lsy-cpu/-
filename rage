local function clamp(val, a, b)
    if val < a then return a end
    if val > b then return b end
    return val
end

local function GetDefaultRaycastParams()
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = { LocalPlayer.Character, workspace.CurrentCamera }
    return params
end

-- 从 origin 向 (point) 做射线，判断是否命中 targetChar 的任意部件
local function IsPointVisibleFrom(origin, point, targetChar)
    if not origin or not point or not targetChar then return false end
    local dir = point - origin
    if dir.Magnitude < 0.001 then return true end
    local params = GetDefaultRaycastParams()
    local res = workspace:Raycast(origin, dir, params)
    if not res then
        return false
    end
    if res.Instance and res.Instance:IsDescendantOf(targetChar) then
        return true
    end
    return false
end

local function IsShielded(char)
    if not char then return false end

    -- Classic ForceField class
    if char:FindFirstChildOfClass("ForceField") then
        return true
    end

    -- Direct "Shield" child (BoolValue / NumberValue / IntValue)
    local shieldObj = char:FindFirstChild("Shield")
    if shieldObj then
        if shieldObj:IsA("BoolValue") and shieldObj.Value then return true end
        if (shieldObj:IsA("NumberValue") or shieldObj:IsA("IntValue")) and shieldObj.Value > 0 then return true end
    end

    -- Check any child whose name contains keywords like "shield", "invul", "god", "protec"
    for _, child in ipairs(char:GetChildren()) do
        local name = (child.Name or ""):lower()
        if name:find("shield") or name:find("invul") or name:find("god") or name:find("protec") then
            if child:IsA("BoolValue") and child.Value then return true end
            if (child:IsA("NumberValue") or child:IsA("IntValue")) and child.Value > 0 then return true end
            if child:IsA("StringValue") and child.Value ~= "" then return true end
            if child:IsA("ObjectValue") and child.Value then return true end
        end
    end

    -- Check attributes on the character and on its Humanoid (common names)
    local checkAttrs = {"Shielded", "IsShielded", "Invulnerable", "GodMode", "Protected", "Protection"}
    for _, attrName in ipairs(checkAttrs) do
        if char.GetAttribute then
            local a = char:GetAttribute(attrName)
            if a == true or (type(a) == "number" and a > 0) then return true end
        end
    end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        for _, attrName in ipairs(checkAttrs) do
            if humanoid.GetAttribute then
                local a = humanoid:GetAttribute(attrName)
                if a == true or (type(a) == "number" and a > 0) then return true end
            end
        end
    end

    return false
end

local function IsVisible(targetPart, fromPos)
    if not targetPart or not fromPos then return false end
    local params = GetDefaultRaycastParams()
    local dir = targetPart.Position - fromPos
    local result = workspace:Raycast(fromPos, dir, params)
    -- 如果没有命中任何东西，说明没有阻挡，视作可见
    if not result then
        return true
    end
    if result.Instance and result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

local function HasClearLineToTarget(spawnPos, targetPart)
    if not spawnPos or not targetPart then return false end
    local params = GetDefaultRaycastParams()
    local dir = targetPart.Position - spawnPos
    if dir.Magnitude < 0.1 then return true end
    local res = workspace:Raycast(spawnPos, dir, params)
    -- 如果没有命中任何东西，说明没有阻挡，视作有清晰直线（不过通常不会发生，因为目标在路径上）
    if not res then
        return true
    end
    if res and res.Instance then
        if res.Instance:IsDescendantOf(targetPart.Parent) then
            return true
        else
            return false
        end
    end
    return false
end

-- 用于在球体内生成均匀的随机偏移向量
local function RandomVectorInSphere(radius)
    if radius <= 0 then return Vector3.new(0,0,0) end
    local v
    repeat
        v = Vector3.new((math.random()*2-1),(math.random()*2-1),(math.random()*2-1))
    until v.Magnitude > 0
    local scale = math.pow(math.random(), 1/3) * radius
    return v.Unit * scale
end

local function SpawnTracer(startPos, endPos)
    if not ENABLE_VISUALS then return end
    if not startPos or not endPos then return end
    local dir = endPos - startPos
    local dist = dir.Magnitude
    if dist <= 0 then return end

    local part = Instance.new("Part")
    part.Name = "TracerPart"
    part.Anchored = true
    part.CanCollide = false
    part.Material = Enum.Material.Neon
    part.Color = TRACER_COLOR
    part.TopSurface = Enum.SurfaceType.Smooth
    part.BottomSurface = Enum.SurfaceType.Smooth
    part.Size = Vector3.new(TRACER_THICKNESS, TRACER_THICKNESS, math.max(dist, 0.01))
    part.CFrame = CFrame.new(startPos, endPos) * CFrame.new(0, 0, -dist / 2)
    part.CastShadow = false
    part.Transparency = 0
    part.Parent = workspace

    local tweenInfo = TweenInfo.new(TRACER_DURATION, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(part, tweenInfo, { Transparency = 1 })
    tween:Play()
    delay(TRACER_DURATION + 0.02, function()
        if part and part.Parent then part:Destroy() end
    end)
end

